package com.universidad.ecologistica.infraestructure.config;

import org.springframework.web.bind.annotation.*;
import com.universidad.ecologistica.application.usecase.*;
import com.universidad.ecologistica.domain.model.ActaConsolidacion;
import com.universidad.ecologistica.domain.repository.ActaRepository;
import java.util.Map;

@RestController
@RequestMapping("/api/actas")
public class ActaController {
	
	private final CrearActaUseCase crearUseCase;
    private final RegistrarFirmaActaUseCase registrarFirmaUseCase;
    private final ActaRepository repository; // inyeccion directo para la consulta simple (REQ-006)

    public ActaController(CrearActaUseCase crearUseCase, 
                          RegistrarFirmaActaUseCase registrarFirmaUseCase,
                          ActaRepository repository) {
        this.crearUseCase = crearUseCase;
        this.registrarFirmaUseCase = registrarFirmaUseCase;
        this.repository = repository;
    }

    // REQ-004: Crear Acta
    @PostMapping
    public ActaConsolidacion crear(@RequestBody Map<String, String> body) {
        return crearUseCase.ejecutar(body.get("clienteId"));
    }

    // REQ-005: Registrar Firma
    @PatchMapping("/{id}/firmar")
    public String registrarFirma(@PathVariable String id) {
        registrarFirmaUseCase.ejecutar(id);
        return "Acta " + id + " firmada exitosamente por el Jefe de Acopio y el Cliente.";
    }

    // REQ-006: Consultar Acta
    @GetMapping("/{id}")
    public ActaConsolidacion consultar(@PathVariable String id) {
        return repository.buscarPorId(id)
                .orElseThrow(() -> new RuntimeException("Acta no encontrada."));
    }

}
