<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jefe de Acopio - Eco-Logística</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">

    <nav class="bg-amber-700 text-white p-4 shadow-md">
        <div class="container mx-auto flex justify-between items-center">
            <h1 class="text-xl font-bold">📦 Eco-Logística Verde en Movimiento| Jefe de Acopio</h1>
            <a href="index.html" class="hover:underline text-amber-200">← Logout</a>
        </div>
    </nav>

    <main class="container mx-auto mt-6 p-4 space-y-8">
        
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <section class="bg-white p-5 rounded-lg shadow border-t-4 border-green-500">
                <h2 class="font-bold text-green-800 mb-4 flex items-center gap-2">📄 Fichas listas para acta</h2>
                <div class="overflow-y-auto max-h-64">
                    <table class="w-full text-xs text-left">
                        <thead class="bg-gray-50"><tr><th class="p-2 border">ID ficha</th><th class="p-2 border">Acción</th></tr></thead>
                        <tbody id="tablaFichasAprobadas"></tbody>
                    </table>
                </div>
                <p class="text-[10px] text-gray-500 mt-3 italic">Solo aparecen fichas con revisión visual aprobada por admisión.</p>
            </section>

            <section class="bg-white p-5 rounded-lg shadow border-t-4 border-amber-500">
                <h2 class="font-bold text-amber-800 mb-4">🆕 Crear acta de consolidación</h2>
                <form id="formCrearActa" class="space-y-4">
                    <input type="text" id="clienteId" required class="w-full p-2 border rounded" placeholder="ID del cliente">
                    <div class="p-3 bg-amber-50 rounded border border-amber-200 text-xs">
                        <p class="font-bold mb-1">Fichas vinculadas:</p>
                        <ul id="fichasSeleccionadas" class="list-disc ml-4 text-amber-900"></ul>
                    </div>
                    <button type="submit" class="w-full bg-amber-600 text-white py-2 rounded font-bold hover:bg-amber-700">Generar acta (REQ-005)</button>
                </form>
            </section>

            <section class="bg-white p-5 rounded-lg shadow border-t-4 border-blue-500">
                <h2 class="font-bold text-blue-800 mb-4">🔍 Verificación de ecoetiquetas</h2>
                <button onclick="generarPaquetePrueba()" class="text-[10px] bg-gray-100 p-1 mb-2 rounded border hover:bg-gray-200 w-full text-center">Inyectar paquete prueba</button>
                <div class="flex gap-1">
                    <input type="text" id="ecoetiqueta" class="flex-1 p-2 border rounded text-sm" placeholder="Escanear Ecoetiqueta">
                    <button onclick="consultarPaquete()" class="bg-blue-600 text-white px-3 rounded font-bold">Ok</button>
                </div>
                <div id="resPaquete" class="mt-3 hidden p-3 bg-gray-50 border rounded text-xs space-y-2">
                    </div>
            </section>
        </div>

        <section class="bg-white p-6 rounded-lg shadow-md border-t-4 border-slate-700">
            <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
                <h2 class="text-xl font-bold">📊 Tablero de auditoría de actas (REQ-006)</h2>
                
                <div class="flex gap-3">
                    <select id="filtroEstado" onchange="filtrarActas()" class="p-2 border rounded text-sm bg-gray-50">
                        <option value="TODOS">Filtrar por Estado...</option>
                        <option value="CREADA">Pendientes de firma</option>
                        <option value="FIRMADA">Listas para despacho (Firmadas)</option>
                    </select>
                    <button onclick="cargarTodo()" class="p-2 bg-gray-200 rounded hover:bg-gray-300">🔄</button>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left border-collapse">
                    <thead class="bg-slate-700 text-white">
                        <tr>
                            <th class="p-3 border">ID acta</th>
                            <th class="p-3 border">Cliente</th>
                            <th class="p-3 border">Estado</th>
                            <th class="p-3 border">Fecha</th>
                            <th class="p-3 border text-center">Acción (REQ-005)</th>
                        </tr>
                    </thead>
                    <tbody id="tablaActasMaster"></tbody>
                </table>
            </div>
        </section>
    </main>

    <script>
        let actasOriginales = [];

        // 1. Cargar Fichas Aprobadas para el Acta
        async function cargarFichasInsumo() {
            const res = await fetch('/api/fichas');
            if(res.ok) {
                const fichas = await res.json();
                const tbody = document.getElementById('tablaFichasAprobadas');
                tbody.innerHTML = "";
                fichas.filter(f => f.estado === 'APROBADA').forEach(f => {
                    tbody.innerHTML += `<tr>
                        <td class="p-2 border font-mono">${f.id}</td>
                        <td class="p-2 border text-center">
                            <button onclick="vincularFicha('${f.id}')" class="text-green-600 font-bold hover:underline">Vincular</button>
                        </td>
                    </tr>`;
                });
            }
        }

        function vincularFicha(id) {
            const lista = document.getElementById('fichasSeleccionadas');
            const li = document.createElement('li');
            li.innerText = id;
            lista.appendChild(li);
        }

        // 2. Gestión de Actas (Listado y Firma)
        async function cargarTodo() {
            cargarFichasInsumo();
            const res = await fetch('/api/actas');
            if(res.ok) {
                actasOriginales = await res.json();
                filtrarActas();
            }
        }

        function filtrarActas() {
            const estado = document.getElementById('filtroEstado').value;
            const tbody = document.getElementById('tablaActasMaster');
            tbody.innerHTML = "";

            actasOriginales
                .filter(a => estado === "TODOS" || a.estado === estado)
                .forEach(a => {
                    const colorEstado = a.estado === 'CREADA' ? 'text-amber-600' : 'text-green-600';
                    tbody.innerHTML += `<tr class="border-b hover:bg-gray-50">
                        <td class="p-3 font-mono font-bold">${a.id}</td>
                        <td class="p-3">${a.clienteId}</td>
                        <td class="p-3 font-bold ${colorEstado}">${a.estado}</td>
                        <td class="p-3 text-gray-500">${new Date(a.fechaCreacion).toLocaleDateString()}</td>
                        <td class="p-3 text-center">
                            ${a.estado === 'CREADA' ? 
                                `<button onclick="registrarFirma('${a.id}')" class="bg-green-100 text-green-700 px-3 py-1 rounded-full border border-green-300 font-bold hover:bg-green-200">✍️ Registrar Firma</button>` : 
                                `<span class="text-xs text-gray-400">Auditoría Bloqueada</span>`}
                        </td>
                    </tr>`;
                });
        }

        async function registrarFirma(id) {
            if(!confirm("¿Formalizar el traspaso de custodia? Esto bloqueará ediciones futuras (REQ-005).")) return;
            const res = await fetch(`/api/actas/${id}/firmar`, { method: 'PATCH' });
            if(res.ok) {
                alert("Acta Firmada Exitosamente. Custodia Legal Formalizada.");
                cargarTodo();
            }
        }

        // Lógica de Paquetes (Similar a la anterior)
        async function generarPaquetePrueba() {
            const eco = "ECO-" + Math.floor(Math.random()*9000);
            await fetch('/api/paquetes/registrar-prueba', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ ecoetiqueta: eco })
            });
            alert("Paquete "+eco+" inyectado.");
        }

        document.getElementById('formCrearActa').addEventListener('submit', async (e) => {
            e.preventDefault();
            const cliente = document.getElementById('clienteId').value;
            const res = await fetch('/api/actas', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ clienteId: cliente })
            });
            if(res.ok) {
                alert("Acta generada. Proceda a la firma en el tablero inferior.");
                document.getElementById('fichasSeleccionadas').innerHTML = "";
                document.getElementById('formCrearActa').reset();
                cargarTodo();
            }
        });

        window.onload = cargarTodo;
    </script>
</body>
</html>